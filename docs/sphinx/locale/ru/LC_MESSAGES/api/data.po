#: ../../../Users/user/manuscript-ocr-1/src/manuscript/data/__init__.py:docstring
#: of manuscript.data.structures.TextSpan:2 bc66626417d44856bc18feda466d00de
msgid "A single detected or recognized text span."
msgstr "Один обнаруженный или распознанный текстовый фрагмент."

#: ../../../Users/user/manuscript-ocr-1/src/manuscript/data/__init__.py:docstring
#: of manuscript.data.structures.TextSpan:4 9f572c88edea4838958c21559fa88bd5
msgid ""
"A text span is the smallest OCR region in the pipeline. It may correspond to "
"a word, a whole text line, or any other contiguous text segment returned by "
"a detector."
msgstr ""
"TextSpan — это наименьшая OCR-область в конвейере. Она может соответствовать "
"слову, целой текстовой строке или любому другому непрерывному текстовому "
"сегменту, возвращённому детектором."

